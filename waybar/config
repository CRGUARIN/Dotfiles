{
    "layer": "top",
    "position": "top",
    "margin-top": 10,     
    "margin-left": 20,    
    "margin-right": 20,  
    // "height": 30, // Comentado para permitir que la barra calcule su altura ideal automáticamente
    "spacing": 2,        

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "network", "pulseaudio", "bluetooth", "backlight", "battery"],

    "hyprland/workspaces": {
        "format": "{name}",     
        "disable-scroll": true, 
        "all-outputs": true, 
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },
   
    "clock": {
        "format": "{:%H:%M • %d.%m}",
        "tooltip": true,
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    }, 

    "tray": {
        "spacing": 12 
    },

    "network": {
        "format-wifi": "󰖩 ",
        "format-ethernet": "󰈀 ",
        "format-disconnected": "󰖪 ",
        "tooltip": true,
        "tooltip-format-ethernet": "Ethernet",
        "tooltip-format-disconnected": "Desactivado",
        "tooltip-format": "Red: {essid}\nIntensidad: {signalStrength}%",
        "on-click": "kitty --class floats -e nmtui"
    },
    
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "󰝟 ",
        "format-icons": {
            "default": [" ", " ", "  "]
        },
        "on-click": "kitty --class floats -e wiremix",
        "tooltip": true,
        "tooltip-format": "{volume}%"
    },    
    
    "bluetooth": {
        "format": "󰂯 ",
        "format-disabled": "󰂲 ", 
        "format-connected": "󰂱 ", 
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias} ({device_battery_percentage}%)",
        "on-click": "kitty --class floats -e bluetui"
    },

    "backlight": {
        "format": "{icon}",
        "format-icons": ["󰃞 ", "󰃟 ", "󰃠 "],
        "on-scroll-up": "brightnessctl set +5%",
        "tooltip": true,
        "tooltip-format": "{percent}%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "󰂄 {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true,
        "tooltip-format": "{capacity}%"
    }
}
