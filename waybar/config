{
    "layer": "top",
    "position": "top",
    "margin-top": 10,     
    "margin-left": 20,    
    "margin-right": 20,  
    "height": 30,        
    "spacing": 2,        

    // Components
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "network", "pulseaudio", "bluetooth", "backlight", "battery"],

    // Components configuration
    "hyprland/workspaces": {
        "format": "{name}",     
        "disable-scroll": true, 
        "all-outputs": true, 
        "persistent-workspaces": {
          "*": [1, 2, 3, 4, 5]
      },
    },
   
    "clock": {
        "format": "{:%H:%M • %d.%m}",
        "tooltip": true,
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    }, 

    "tray": {
        "spacing": 2
    },

    "network": {
        "format-wifi": "󰖩 ",
        "format-ethernet": "󰈀 ",
        "format-disconnected": "󰖪 ",
        "tooltip": true,
        "tooltip-format-ethernet": "Ethernet",
        "tooltip-format-disconnected": "Desactivado",
        "tooltip-format": "Red: {essid}\nIntensidad: {signalStrength}%",
        "on-click": "kitty --class floats -e nmtui",
    },
    
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "󰝟 ",
        "format-icons": {
            "default": [" ", " ", "  "]
        },
        "on-click": "kitty --class floats -e wiremix", // Si haces clic, abre el control de volumen (debes tenerlo instalado)
        "tooltip": true,
        "tooltip-format": "{volume}%",
    },    
    
     "bluetooth": {
        "format": "󰂯  ",
        "format-disabled": "󰂲  ", 
        "format-connected": "󰂱  ", 
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias} ({device_battery_percentage}%)",
        "on-click": "kitty --class floats -e bluetui"
    },

    "backlight": {
        "format": "{icon}",
        "format-icons": ["󰃞 ", "󰃟 ", "󰃠 "], // Iconos de Nerd Fonts de menos a más brillo
        "on-scroll-up": "brightnessctl set +5%",   // Sube el brillo girando la rueda del ratón
        "tooltip": true,
        "tooltip-format": "{percent}%",
        "on-scroll-down": "brightnessctl set 5%-"  // Baja el brillo girando la rueda del ratón
    },

    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true,
        "tooltip-format": "{capacity}%",
    }

    
}
